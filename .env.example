# Supabase (for Insights API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# Insights API base URL (used by MCP server and optionally agent)
INSIGHTS_API_URL=http://localhost:8001

# MCP server URL (used by agent to connect to Insights MCP)
MCP_SERVER_URL=http://localhost:8002/mcp

# MCP server port (when running mcp_server locally)
MCP_PORT=8002

# OpenAI (for the agent)
OPENAI_API_KEY=sk-...

# Optional: Insights API port when run directly
PORT=8001
